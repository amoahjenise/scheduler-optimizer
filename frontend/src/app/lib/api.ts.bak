export type PatientStatus =
  | "stable"
  | "improved"
  | "unchanged"
  | "worsening"
  | "critical";
export type AcuityLevel = "low" | "moderate" | "high" | "critical";
export type IsolationType =
  | "none"
  | "contact"
  | "droplet"
  | "airborne"
  | "neutropenic"
  | "protective"
  | "cytotoxic";
export type ShiftType = "day" | "evening" | "night";

export interface HandoverPatient {
  id: string;
  mrn: string;
  first_name: string;
  last_name: string;
  room_number: string;
  bed?: string;
  diagnosis?: string;
}

